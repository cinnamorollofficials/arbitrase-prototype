PORT=5001

# PostgreSQL Database Configuration
# DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/arbitrage_db
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=arbitrage_db
DB_TEST_NAME=arbitrage_db_test
DB_SSL=false

# Redis cache shared by backend and price-worker
REDIS_URL=redis://localhost:6379

# Price worker polling keeps latest prices fast, while history is sampled to keep Redis RAM predictable.
POLL_INTERVAL_SECONDS=10
HISTORY_TTL_SECONDS=86400
HISTORY_SAMPLE_SECONDS=60
HISTORY_MAX_POINTS=1440

# Market data from price-worker is marked stale after this age.
MARKET_DATA_STALE_AFTER_MS=30000

# Mobee market data API key, passed by price-worker as X-API-Key.
MOBEE_API_KEY=
MOBEE_API_SECRET=
MOBEE_CONCURRENCY=5
